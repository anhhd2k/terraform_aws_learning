# Local .terraform folder (contains plugins and modules)
**/.terraform/*

# .tfstate files (can contain secrets in plain text)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude any .tfvars files (usually contain sensitive credentials)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc